# Copy this file to .env for local Docker Compose overrides.
# Keep real local secrets in .env only. Do not commit .env.

# MySQL container configuration
MYSQL_DATABASE=price_tracker
MYSQL_PORT=3306
# MYSQL_USER=<local-mysql-user>
# MYSQL_PASSWORD=<local-mysql-password>
# MYSQL_ROOT_PASSWORD=<local-root-password>

# Redis container and Spring Boot configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_TIMEOUT=5s
# REDIS_PASSWORD=<local-redis-password>

# RabbitMQ container and Spring Boot configuration
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_VIRTUAL_HOST=/
# RABBITMQ_USERNAME=<local-rabbitmq-user>
# RABBITMQ_PASSWORD=<local-rabbitmq-password>
